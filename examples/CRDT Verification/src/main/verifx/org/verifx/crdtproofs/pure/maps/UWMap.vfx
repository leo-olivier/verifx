import org.verifx.crdtproofs.VersionVector
import org.verifx.crdtproofs.pure.TaggedOp
import org.verifx.crdtproofs.pure.PerfectPure
import org.verifx.crdtproofs.pure.maps.AbstractMap

object MapOps {
  enum MapOp {
    Update(k: String) | Delete(k: String)
  }
}

class UWMap(polog: Set[TaggedOp[MapOp]], children: Map[String, PerfectPure])
    extends AbstractMap[MapOp] {

  def isUpdateOn(o: MapOp, k: String): Boolean = {
    o match {
      case Update(kk) => k == kk
      case _          => false
    }
  }

  def create(
      polog: Set[TaggedOp[MapOp]],
      children: Map[String, PerfectPure]
  ): UWMap = new UWMap(polog, children)

  def selfRedundant(
      op: TaggedOp[MapOp],
      polog: Set[TaggedOp[MapOp]]
  ): Boolean = op.o match {
    case Delete(_) => true
    case _         => false
  }

  def redundantBy(x: TaggedOp[MapOp], y: TaggedOp[MapOp]): Boolean = {
    x.t.before(y.t) && (y.o match {
      case Update(k) => this.isUpdateOn(x.o, k)
      case Delete(k) => this.isUpdateOn(x.o, k)
    })
  }

  def childNeedsReset(
      child: String,
      x: TaggedOp[MapOp]
  ): Tuple[Boolean, Boolean] = {
    new Tuple(
      x.o match {
        case Delete(k) => k == child
        case _         => false
      },
      false
    )
  }

  def delete(timestamp: VersionVector, k: String): UWMap = {
    val res = this.effect(new Delete(k), timestamp)
    new UWMap(res.fst, res.snd)
  }

  def update(timestamp: VersionVector, k: String, o: PerfectOp) = {
    val res = this.nestedEffect(k, timestamp, new Update(k), o)
    new UWMap(res.fst, res.snd)
  }
}

